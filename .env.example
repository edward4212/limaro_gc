# =====================================================================
# Limaro SGC - Variables de entorno (copiar a .env y ajustar)
# =====================================================================

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=limarocloud_limaro
DB_USER=root
DB_PASS=

# Aplicación
APP_URL=https://limaro.limaro.cloud
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Bogota

# Seguridad AES (NO cambiar sin migrar todas las claves)
AES_KEY=kddbjw8b3d

# Sesión
SESSION_NAME=LIMARO_SGC
SESSION_LIFETIME=7200

# Upload
UPLOAD_MAX_SIZE=20971520
UPLOAD_PATH=/public/storage
