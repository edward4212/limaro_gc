# =====================================================================
# .htaccess raíz - Limaro SGC
# Redirige todas las peticiones a la carpeta public/
# (oculta /public/ de las URLs sin exponer el código fuente)
# =====================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso directo a carpetas sensibles
    RewriteRule ^(app|config|sql|docs|storage)(/|$) - [F,L]

    # Bloquear archivos de configuración
    RewriteRule ^\.env - [F,L]
    RewriteRule ^README\.md - [F,L]

    # Si la petición no es a /public/, reenviar internamente a /public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Proteger archivos sensibles
<FilesMatch "\.(env|sql|md|log|json|lock)$">
    Require all denied
</FilesMatch>

Options -Indexes

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_value upload_max_filesize 25M
   php_value post_max_size 30M
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 10000
   php_value memory_limit 384M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/home/limarocloud/limaro.limaro.cloud/storage/sessions"
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_value upload_max_filesize 25M
   php_value post_max_size 30M
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 10000
   php_value memory_limit 384M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/home/limarocloud/limaro.limaro.cloud/storage/sessions"
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
