# =====================================================================
# .htaccess raíz - Limaro SGC
# Redirige todas las peticiones a la carpeta public/
# (oculta /public/ de las URLs sin exponer el código fuente)
# =====================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear acceso directo a carpetas sensibles
    RewriteRule ^(app|config|sql|docs|storage)(/|$) - [F,L]

    # Bloquear archivos de configuración
    RewriteRule ^\.env - [F,L]
    RewriteRule ^README\.md - [F,L]

    # Si la petición no es a /public/, reenviar internamente a /public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Proteger archivos sensibles
<FilesMatch "\.(env|sql|md|log|json|lock)$">
    Require all denied
</FilesMatch>

Options -Indexes

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
